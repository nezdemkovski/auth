{
  "name": "@nezdemkovski/auth-integration",
  "version": "0.1.0",
  "description": "Thin Better Auth integration for Nezdemkovski auth realms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezdemkovski/auth.git",
    "directory": "packages/auth-integration"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/identity",
    "dist/provider",
    "dist/resource",
    "dist/shared",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "better-auth": "1.7.0-rc.1"
  },
  "devDependencies": {
    "better-auth": "1.7.0-rc.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
