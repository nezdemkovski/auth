{
  "name": "@nezdemkovski/auth-oauth-resource",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.7.0-rc.1",
    "better-auth": "1.7.0-rc.1"
  }
}
