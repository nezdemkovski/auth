{
  "name": "@nezdemkovski/auth-delivery",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nezdemkovski/auth-platform-database": "workspace:*",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.10",
    "drizzle-orm": "1.0.0-rc.4",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17"
  }
}
