{
  "name": "@nezdemkovski/auth-server",
  "version": "0.1.0",
  "description": "Server-side realm token verification for the Nezdemkovski auth platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezdemkovski/auth.git",
    "directory": "packages/auth-server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nezdemkovski/auth-contracts": "0.1.0",
    "jose": "6.2.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
