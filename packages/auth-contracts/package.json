{
  "name": "@nezdemkovski/auth-contracts",
  "version": "0.3.0",
  "description": "Stable business contracts for Nezdemkovski platform resources",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezdemkovski/auth.git",
    "directory": "packages/auth-contracts"
  },
  "type": "module",
  "files": [
    "dist/billing",
    "dist/storage",
    "README.md"
  ],
  "exports": {
    "./billing": {
      "types": "./dist/billing/contract.d.ts",
      "import": "./dist/billing/contract.js",
      "default": "./dist/billing/contract.js"
    },
    "./storage": {
      "types": "./dist/storage/contract.d.ts",
      "import": "./dist/storage/contract.js",
      "default": "./dist/storage/contract.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/billing/contract.ts ./src/storage/contract.ts --outdir ./dist --root ./src --target browser --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
