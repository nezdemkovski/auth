{
  "name": "@nezdemkovski/auth-contracts",
  "version": "0.2.0",
  "description": "Stable business contracts for Nezdemkovski platform resources",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezdemkovski/auth.git",
    "directory": "packages/auth-contracts"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/billing",
    "dist/shared",
    "dist/storage",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --packages external --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
