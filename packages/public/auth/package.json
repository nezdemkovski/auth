{
  "name": "@nezdemkovski/auth",
  "version": "0.1.2",
  "description": "Authentication SDK for Nezdemkovski realms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nezdemkovski/auth.git",
    "directory": "packages/public/auth"
  },
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "react-native": "./dist/client/native.js",
      "browser": "./dist/client/web.js",
      "import": "./dist/client/web.js",
      "default": "./dist/client/web.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js",
      "default": "./dist/billing/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "default": "./dist/storage/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-auth": "1.7.0-rc.1",
    "oauth4webapi": "3.8.6"
  },
  "peerDependencies": {
    "expo-auth-session": ">=7 <8",
    "expo-crypto": ">=14 <16",
    "expo-secure-store": ">=14 <16"
  },
  "peerDependenciesMeta": {
    "expo-auth-session": {
      "optional": true
    },
    "expo-crypto": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.7",
    "expo-secure-store": "~15.0.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
