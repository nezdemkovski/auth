{
  "name": "@nezdemkovski/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "email:dev": "email dev --dir src/email/previews --port 3001",
    "start": "bun src/index.ts",
    "build:login": "vite build --config vite.login.config.ts",
    "build": "bun run build:login && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@better-auth/agent-auth": "0.5.1",
    "@better-auth/drizzle-adapter": "1.6.11",
    "@better-auth/oauth-provider": "1.6.11",
    "@better-auth/passkey": "1.6.11",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-router": "1.170.7",
    "better-auth": "1.6.11",
    "drizzle-orm": "1.0.0-rc.3",
    "hono": "4.12.21",
    "pg": "8.21.0",
    "react": "19.2.1",
    "react-aria-components": "1.17.0",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@react-email/ui": "6.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "latest",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "1.0.0-rc.3",
    "react-email": "6.3.0",
    "tailwindcss": "4.3.0",
    "typescript": "latest",
    "vite": "8.0.14"
  }
}
