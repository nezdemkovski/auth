{
  "name": "@nezdemkovski/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@nezdemkovski/auth-api",
    "dev:compose:up": "docker compose -f dev/docker-compose.yml up",
    "dev:compose:down": "docker compose -f dev/docker-compose.yml down",
    "dev:admin": "turbo run dev --filter=@nezdemkovski/auth-admin",
    "dev:login": "turbo run dev --filter=@nezdemkovski/auth-login",
    "email:dev": "turbo run email:dev --filter=@nezdemkovski/auth-api",
    "start": "turbo run start --filter=@nezdemkovski/auth-api",
    "build:admin": "turbo run build --filter=@nezdemkovski/auth-admin",
    "build:login": "turbo run build --filter=@nezdemkovski/auth-login",
    "build:api": "turbo run build --filter=@nezdemkovski/auth-api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=@nezdemkovski/auth-api",
    "test:integration": "cd apps/api && bun run test:integration",
    "test:integration:up": "docker compose -f dev/docker-compose.integration.yml up -d --wait",
    "test:integration:down": "docker compose -f dev/docker-compose.integration.yml down -v"
  },
  "overrides": {
    "drizzle-orm": "1.0.0-rc.4"
  },
  "devDependencies": {
    "@react-email/ui": "6.6.9",
    "@tailwindcss/vite": "4.3.2",
    "@types/bun": "1.3.14",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "1.0.0-rc.4",
    "react-email": "6.6.9",
    "tailwindcss": "4.3.2",
    "turbo": "2.10.4",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  }
}
