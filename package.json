{
  "name": "@nezdemkovski/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@nezdemkovski/auth-server",
    "dev:admin": "turbo run dev --filter=@nezdemkovski/auth-admin",
    "dev:hosted": "turbo run dev --filter=@nezdemkovski/auth-hosted",
    "email:dev": "turbo run email:dev --filter=@nezdemkovski/auth-server",
    "start": "turbo run start --filter=@nezdemkovski/auth-server",
    "build:admin": "turbo run build --filter=@nezdemkovski/auth-admin",
    "build:hosted": "turbo run build --filter=@nezdemkovski/auth-hosted",
    "build:server": "turbo run build --filter=@nezdemkovski/auth-server",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=@nezdemkovski/auth-server"
  },
  "devDependencies": {
    "@react-email/ui": "6.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "1.0.0-rc.3",
    "react-email": "6.3.0",
    "tailwindcss": "4.3.0",
    "turbo": "2.6.3",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  }
}
