PORT=3000
AUTH_PUBLIC_BASE_URL=http://localhost:3000
AUTH_ADMIN_EMAIL=admin@localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_AUTO_MIGRATE=true

# Optional. When set, rate limits and hosted auth codes are shared through Redis.
# Without it, the service falls back to in-memory stores for local development.
# REDIS_URL=redis://localhost:6379

# Trust Cloudflare/nginx forwarded IP headers for auth audit logs and rate
# limiting. Enable only when the service is reachable exclusively through a
# proxy that strips client-supplied forwarding headers.
TRUST_PROXY_HEADERS=false
