PORT=3000
AUTH_PUBLIC_BASE_URL=http://localhost:3000
AUTH_ADMIN_EMAIL=admin@localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-a-different-32-character-secret
AUTH_AUTO_MIGRATE=true

# Optional delivery. Email verification becomes mandatory when a sender is set.
EMAIL_PROVIDER=none
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_test
# EMAIL_FROM=Auth <auth@example.com>
# EMAIL_PROVIDER=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_EMAIL_API_TOKEN=

# Optional. When set, rate limits and login auth codes are shared through Redis.
# Without it, the service falls back to in-memory stores for local development.
# REDIS_URL=redis://localhost:6379

# Trust Cloudflare/nginx forwarded IP headers for auth audit logs and rate
# limiting. Enable only when the service is reachable exclusively through a
# proxy that strips client-supplied forwarding headers.
TRUST_PROXY_HEADERS=false

# Optional deployment-managed S3-compatible storage. When these are set, realm
# storage settings in the admin UI only expose enable/disable.
AUTH_STORAGE_PROVIDER=none
# AUTH_STORAGE_ENDPOINT=http://localhost:9000
# AUTH_STORAGE_REGION=us-east-1
# AUTH_STORAGE_BUCKET=auth-public
# AUTH_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/auth-public
# AUTH_STORAGE_ACCESS_KEY_ID=auth-dev-access-key
# AUTH_STORAGE_SECRET_ACCESS_KEY=auth-dev-secret-key
