PORT=3000
AUTH_PUBLIC_BASE_URL=http://localhost:3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_AUTO_MIGRATE=true

