PORT=3000
AUTH_PUBLIC_BASE_URL=http://localhost:3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_AUTO_MIGRATE=true

# Optional. When set, auth rate limits are shared across replicas through Redis.
# Without it, the service falls back to an in-memory limiter.
# REDIS_URL=redis://localhost:6379

# Trust Cloudflare/nginx forwarded IP headers for auth audit logs and rate
# limiting. Enable only when the service is reachable exclusively through a
# proxy that strips client-supplied forwarding headers.
TRUST_PROXY_HEADERS=false

# JSON array. Each project is isolated into its own Postgres schema.
AUTH_PROJECTS='[
  {
    "slug": "demo",
    "name": "Demo",
    "schema": "demo_auth",
    "trustedOrigins": ["http://localhost:5173"]
  }
]'
